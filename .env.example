# ─── Notion ──────────────────────────────────────────────────────────────────
# Get from: notion.so → Settings → My connections → Develop or manage integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID of the parent Notion page where the Blog Queue database will be created.
# Open any Notion page, click ••• → Copy link → the long ID after the last / and before the ?
# Only needed once to run: node scripts/setup-notion.js
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Filled in automatically after running setup-notion.js
NOTION_BLOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Netlify ─────────────────────────────────────────────────────────────────
# Get from: Netlify dashboard → Site → Build & deploy → Build hooks → Add build hook
NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/xxxxxxxxxxxxxxxxxx

# ─── Notifications (optional) ────────────────────────────────────────────────
# Slack incoming webhook — get from: api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
